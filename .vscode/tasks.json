    {
      "label": "Inspect remote grafana files",
      "type": "shell",
      "command": "ansible",
      "args": [
        "-i",
        "src/inventory.yml",
        "habiki",
        "-b",
        "-m",
        "shell",
        "-a",
        "ls -la /etc/grafana; echo '---'; ls -la /etc/grafana/dashboards || true; echo '---'; find /etc/grafana/provisioning -maxdepth 3 -type f | sort || true",
        "--vault-password-file",
        "/home/scetrov/.ansible/nixos_vault_password"
      ],
      "isBackground": false,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Deploy nixos cleanup",
      "type": "shell",
      "command": "./scripts/play.sh",
