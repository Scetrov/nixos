# Blueprint: service-account-api
#
# Created by Ansible template deployment. Authentik imports this through
# the API to create the automation service-account with a non-expiring
# API token.
#
version: 1
metadata:
  name: service-account-api
entries:
  # ── Service-account user ───────────────────────────────────────────────
  - model: authentik_core.user
    id: service-account-api-user
    identifiers:
      username: "{{ authentik_config_service_account_username }}"
    attrs:
      name: API Automation
      is_active: true
      type: service_account
      groups:
        # Built-in superuser group created by Authentik on first boot.
        - !Find [authentik_core.group, [name, authentik Admins]]

  # ── Non-expiring API token ────────────────────────────────────────────
  - model: authentik_core.token
    id: service-account-api-token
    identifiers:
      identifier: ak-api-token-automation
    attrs:
      intent: api
      expiring: false
      expires: null
      key: "{{ authentik_config_api_token | default(authentik_api_token) }}"
      user: !Ref service-account-api-user
