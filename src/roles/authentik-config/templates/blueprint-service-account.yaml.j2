# Blueprint: service-account-api
#
# Created by Ansible template deployment. Authentik processes this at
# start-up and creates the automation service-account with a non-expiring
# API token.
#
version: 1
metadata:
  name: service-account-api
entries:
  # ── Service-account user ───────────────────────────────────────────────
  - model: authentik_core.user
    id: service-account-api-user
    ident: ak-service-account-api
    attrs:
      username: api-automation
      name: API Automation
      is_active: true
      type: service_account
    groups:
      # Built-in superuser group (created by Authentik on first boot)
      - !Ident goauthentik.io/groups:authentik-admins

  # ── Non-expiring API token ────────────────────────────────────────────
  - model: authentik_core.token
    id: service-account-api-token
    ident: ak-api-token-automation
    attrs:
      intent: api
      expires: null
      key: "{{ authentik_config_api_token | default(authentik_api_token) }}"
    user: !Ref service-account-api-user
