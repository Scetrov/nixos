        "y": 1
      },
      "id": 2,
      "options": {
        "content": "## Scope\n\n- This dashboard summarizes house-wide indoor climate from the retained `mimir` datasource.\n- Temperature and humidity are aggregated across the curated indoor sensor allowlist.\n- Air quality is represented with CO2 plus PM2.5 and PM10 particulate measurements, because the `air_quality` entity names do not currently export value series.",
        "mode": "markdown"
      },
      "title": "What This Shows",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "decimals": 1,
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 0,
        "y": 5
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "valueAndName"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "editorMode": "code",
          "expr": "avg(homeassistant_sensor_temperature_celsius{job=\"home-assistant\",service=\"home-assistant\",entity=~\"sensor[.](utility_room_sensor_temperature|upstairs_hallway_sensor_temperature|kitchen_sensor_temperature|bathroom_sensor_temperature|wifi_smart_switch_temperature|wifi_smart_switch_temperature_2|indoor_outdoor_meter_4bdd_temperature|indoor_outdoor_meter_dbb6_temperature|indoor_outdoor_meter_6d05_temperature|indoor_outdoor_meter_9aff_temperature|thermo_hygrometer_office_temperature|indoor_outdoor_meter_3393_temperature|indoor_outdoor_meter_1d40_temperature|thermo_hygrometer_living_area_temperature)\"})",
          "instant": true,
          "legendFormat": "Average indoor temperature",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Average Temperature",
      "type": "stat"
    },
